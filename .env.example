# ── Database (Supabase) ──────────────────────────────
SUPABASE_URL=your_project_url_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── SoundCloud ───────────────────────────────────────
SC_CLIENT_ID=your_client_id_here
SC_CLIENT_SECRET=your_client_secret_here

# ── Beatport ─────────────────────────────────────────
BEATPORT_USERNAME=your_username_here
